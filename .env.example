# SML Fleet — Environment Variables

# MongoDB (Source of Truth)
MONGO_URI=mongodb://mongodb:27017/smlfleet
MONGO_DB=smlfleet

# PostgreSQL (Query Layer — rebuildable จาก MongoDB)
# Docker: ใช้ host.docker.internal เพื่อเข้าถึง PostgreSQL ที่ติดตั้งบน host
POSTGRES_URI=postgres://smlfleet:smlfleet_password@host.docker.internal:5432/smlfleet?sslmode=disable

# Kafka (ชื่อ service ใน docker-compose)
KAFKA_BROKERS=kafka:9094
KAFKA_GROUP_ID=fleet-pgsql-sync

# Longdo Map API
LONGDO_MAP_API_KEY=your_longdo_api_key

# LINE OA
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_access_token

# Claude API
ANTHROPIC_API_KEY=your_claude_api_key
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=smlfleet-files
R2_PUBLIC_URL=https://files.smlfleet.com

# Stripe (UCP)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRY=24h

# Server
PORT=8080
ENV=production
